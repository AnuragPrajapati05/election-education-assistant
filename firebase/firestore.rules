// firebase/firestore.rules
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helper functions ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isValidUserData() {
      return request.resource.data.keys().hasAll(['email', 'displayName', 'role', 'createdAt'])
        && request.resource.data.role in ['user', 'admin']
        && request.resource.data.displayName.size() <= 100
        && request.resource.data.email.size() <= 200;
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUserData();
      allow update: if isOwner(uid) && 
        // Users cannot change their own role
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    // ─── Chat Sessions ────────────────────────────────────────────────────────
    match /chatSessions/{sessionId} {
      allow read, write: if isAuthenticated() && 
        resource.data.uid == request.auth.uid;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
          get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.uid == request.auth.uid;
        allow create: if isAuthenticated();
        allow update, delete: if false; // Messages are immutable
      }
    }

    // ─── Eligibility Checks ───────────────────────────────────────────────────
    match /eligibilityChecks/{checkId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && 
        request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // Audit trail — no modifications
    }

    // ─── Analytics ───────────────────────────────────────────────────────────
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write analytics
    }

    // ─── Booths (public read) ─────────────────────────────────────────────────
    match /pollingBooths/{boothId} {
      allow read: if true;   // Public data
      allow write: if isAdmin();
    }

    // ─── FAQs (public read) ───────────────────────────────────────────────────
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
